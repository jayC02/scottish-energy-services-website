---
import { services } from '../data/services';
const preview = Astro.props.preview ?? false;
const list = preview ? services : services;
---
<section class="section service-band">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Core Services</p>
      <h2 class="section-title">Technical compliance services structured for performance, clarity, and confidence.</h2>
      <p class="lead">Our service architecture is designed to support transactions, design programmes, and statutory obligations with dependable delivery quality.</p>
    </div>
    <div class="service-grid">
      {list.map((service, index) => (
        <article class="card service-card" data-reveal style={`--index:${index};`}>
          <p class="service-index">{String(index + 1).padStart(2, '0')}</p>
          <h3>{service.title}</h3>
          <p>{service.short}</p>
          <a href={`/services/${service.slug}`} class="service-link">View service <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-band {
    position: relative;
  }
  .service-grid {
    margin-top: 1.8rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  .service-card {
    display: grid;
    gap: .82rem;
    padding: 1.45rem;
    min-height: 238px;
    transition: transform .3s cubic-bezier(.2,.8,.2,1), border-color .25s ease, box-shadow .3s ease, background .3s ease;
    background: linear-gradient(170deg, rgba(255,255,255,.95), rgba(246,251,255,.95));
    position: relative;
    overflow: hidden;
  }
  .service-card::after {
    content: '';
    position: absolute;
    inset: auto -20% -45% 40%;
    height: 70%;
    background: radial-gradient(circle, rgba(21,130,188,0.14), transparent 67%);
    pointer-events: none;
    transition: transform .35s ease;
  }
  .service-card:hover { transform: translateY(-6px); border-color: #b7cde0; box-shadow: var(--shadow); }
  .service-card:hover::after { transform: translate3d(0, -9px, 0); }
  .service-index {
    margin: 0;
    color: color-mix(in oklab, var(--brand) 75%, white);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 700;
    letter-spacing: .03em;
    font-size: .8rem;
  }
  h3 { margin: 0; color: var(--text-strong); font-size: 1.16rem; line-height: 1.3; }
  p { color: var(--muted); margin: 0; }
  .service-link { color: var(--brand-strong); font-weight: 600; margin-top: auto; }

  @media (max-width: 980px) {
    .service-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 700px) {
    .service-grid { grid-template-columns: 1fr; }
  }
</style>
