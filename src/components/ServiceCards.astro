---
import { services } from '../data/services';
const preview = Astro.props.preview ?? false;
const list = preview ? services : services;
---
<section class="section surface-band services-shell">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Core Services</p>
      <h2 class="section-title">Advanced compliance and building performance services, delivered with technical precision.</h2>
      <p class="lead">Our nine-service portfolio is structured to support domestic, commercial, and development-led projects with clear outputs and dependable turnaround.</p>
    </div>
    <div class="services-grid cards">
      {list.map((service, index) => (
        <article class={`card service-card ${index < 2 ? 'feature' : ''}`} data-reveal>
          <p class="service-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</p>
          <h3>{service.title}</h3>
          <p>{service.short}</p>
          <a href={`/services/${service.slug}`} class="service-link">View service <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-shell { overflow: clip; }
  .cards { margin-top: 1.4rem; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1rem;
  }
  .service-card {
    grid-column: span 4;
    display: grid;
    gap: .85rem;
    position: relative;
    overflow: hidden;
    min-height: 208px;
    border-color: rgba(185, 201, 218, 0.72);
    background: linear-gradient(170deg, rgba(255, 255, 255, 0.95), rgba(246, 250, 255, 0.88));
    transition: transform .28s ease, border-color .28s ease, box-shadow .28s ease;
  }
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 120% at 0% 0%, rgba(68, 146, 197, 0.1), transparent 55%);
    pointer-events: none;
  }
  .service-card.feature { grid-column: span 6; min-height: 220px; }
  .service-card:hover { transform: translateY(-6px); border-color: #9ebbd4; box-shadow: var(--shadow); }
  .service-number {
    margin: 0;
    font-size: .76rem;
    letter-spacing: .12em;
    font-weight: 700;
    color: var(--brand);
  }
  h3 { margin: 0; color: var(--text-strong); font-size: 1.12rem; line-height: 1.28; }
  p { color: var(--muted); margin: 0; max-width: 44ch; }
  .service-link { margin-top: auto; color: var(--brand-strong); font-weight: 650; }

  @media (max-width: 1020px) {
    .service-card, .service-card.feature { grid-column: span 6; }
  }
  @media (max-width: 760px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-card, .service-card.feature { grid-column: auto; min-height: unset; }
  }
</style>
