---
import { services } from '../data/services';
const preview = Astro.props.preview ?? false;
const list = preview ? services : services;
---
<section class="section service-band">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Core Services</p>
      <h2 class="section-title">Nine specialist services delivered with technical discipline and clear communication.</h2>
      <p class="lead">From one-off assessments to portfolio instruction programmes, every service is structured for practical delivery, dependable compliance, and commercially useful reporting.</p>
    </div>
    <div class="service-grid">
      {list.map((service, index) => (
        <article class="card service-card" data-reveal style={`--index:${index};`}>
          <p class="service-index">{String(index + 1).padStart(2, '0')}</p>
          <h3>{service.title}</h3>
          <p class="service-description">{service.short}</p>
          <ul class="service-highlights">
            {service.highlights.slice(0, 2).map((item) => <li>{item}</li>)}
          </ul>
          <a href={`/services/${service.slug}`} class="service-link">View service <span aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .service-band { position: relative; }
  .service-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 1.1rem;
  }
  .service-card {
    grid-column: span 4;
    display: grid;
    gap: .82rem;
    padding: 1.55rem;
    min-height: 286px;
    transition: transform .3s cubic-bezier(.2,.8,.2,1), border-color .25s ease, box-shadow .3s ease;
    background: linear-gradient(170deg, rgba(255,255,255,.98), rgba(246,251,255,.94));
    border-color: #d5e0eb;
    position: relative;
  }
  .service-card:hover { transform: translateY(-5px); border-color: #b7cde0; box-shadow: var(--shadow); }
  .service-index {
    margin: 0;
    color: color-mix(in oklab, var(--brand) 75%, white);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-weight: 700;
    letter-spacing: .03em;
    font-size: .8rem;
  }
  h3 { margin: 0; color: var(--text-strong); font-size: 1.17rem; line-height: 1.3; }
  .service-description { color: var(--muted); margin: 0; }
  .service-highlights {
    margin: .15rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: .34rem;
  }
  .service-highlights li {
    color: #52657a;
    font-size: .9rem;
    padding-left: 1rem;
    position: relative;
  }
  .service-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: .48rem;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--brand) 70%, white);
  }
  .service-link { color: var(--brand-strong); font-weight: 600; margin-top: auto; }

  @media (max-width: 1080px) {
    .service-card { grid-column: span 6; min-height: 270px; }
  }
  @media (max-width: 700px) {
    .service-card { grid-column: 1 / -1; min-height: unset; }
  }
</style>
