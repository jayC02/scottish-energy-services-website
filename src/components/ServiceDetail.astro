---
import type { Service } from '../data/services';
const { service } = Astro.props as { service: Service };
---
<section class="section">
  <div class="container grid grid-2">
    <div data-reveal>
      <p class="eyebrow">Service Overview</p>
      <h1 class="section-title">{service.title}</h1>
      <p class="lead">{service.intro}</p>
      <ul class="highlights">
        {service.highlights.map((item) => <li>{item}</li>)}
      </ul>
      <p><strong>Typical turnaround:</strong> {service.turnaround}</p>
      <a class="btn btn-primary" href="/quote">Request a quote</a>
    </div>
    <aside class="card detail" data-reveal>
      <h2>Who this is for</h2>
      <ul>
        {service.forWho.map((item) => <li>{item}</li>)}
      </ul>
      <h2>What is included</h2>
      <ul>
        {service.whatIncluded.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </div>
</section>

<style>
  .highlights {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: grid;
    gap: .35rem;
  }
  .highlights li {
    color: var(--muted);
    position: relative;
    padding-left: 1rem;
  }
  .highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: .6rem;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent);
  }
  .detail h2 { margin: 0 0 .6rem; font-size: 1.12rem; color: var(--text-strong); }
  .detail ul { margin: 0 0 1rem; padding-left: 1rem; color: var(--muted); }
  .detail li { margin-bottom: .35rem; }
</style>
