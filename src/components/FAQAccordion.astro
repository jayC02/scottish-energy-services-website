---
import { faqs } from '../data/faqs';
const limit = Astro.props.limit;
const items = limit ? faqs.slice(0, limit) : faqs;
---
<section class="section surface-band">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">FAQs</p>
      <h2 class="section-title">Frequently asked questions</h2>
    </div>
    <div class="faq-list">
      {items.map((faq, i) => (
        <details class="card faq" data-reveal>
          <summary>{faq.question}</summary>
          <p id={`faq-${i}`}>{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list { display: grid; gap: .85rem; }
  summary { cursor: pointer; font-weight: 650; color: var(--text-strong); }
  .faq p { color: var(--muted); margin-bottom: 0; }
</style>
