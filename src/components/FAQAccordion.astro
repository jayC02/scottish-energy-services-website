---
import { faqs } from '../data/faqs';
const limit = Astro.props.limit;
const items = limit ? faqs.slice(0, limit) : faqs;
---
<section class="section surface-band">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">FAQs</p>
      <h2 class="section-title">Practical answers before you instruct</h2>
      <p class="lead">Clear guidance on timescales, coverage, compliance requirements, and service scope.</p>
    </div>
    <div class="faq-list">
      {items.map((faq, i) => (
        <details class="card faq" data-reveal>
          <summary>
            <span>{faq.question}</span>
            <em>{faq.category}</em>
          </summary>
          <p id={`faq-${i}`}>{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list { display: grid; gap: .85rem; }
  .faq { padding: 1.1rem 1.2rem; }
  summary {
    cursor: pointer;
    font-weight: 650;
    color: var(--text-strong);
    display: flex;
    justify-content: space-between;
    gap: .8rem;
    align-items: center;
  }
  summary em {
    font-style: normal;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--brand-strong);
    background: color-mix(in oklab, var(--brand-soft) 75%, white);
    border: 1px solid #c5d8ea;
    border-radius: 999px;
    padding: .2rem .5rem;
    white-space: nowrap;
  }
  .faq p { color: var(--muted); margin: .75rem 0 0; }
  @media (max-width: 620px) {
    summary { flex-direction: column; align-items: flex-start; }
  }
</style>
