---
import { siteConfig } from '../data/site';
---
<footer class="section footer">
  <div class="container footer-grid">
    <div>
      <img class="footer-logo" src="SES logo horizontal@4x.png" alt="Scottish Energy Services" loading="lazy" decoding="async" />
      <p class="lead">Trusted assessments and technical compliance delivery for homeowners, landlords, letting agents, and commercial property teams across the UK.</p>
    </div>
    <div>
      <h4>Contact</h4>
      <p><a href={`tel:${siteConfig.phone}`}>{siteConfig.phone}</a><br /><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a><br />{siteConfig.address}</p>
    </div>
    <div>
      <h4>Quick Links</h4>
      <p><a href="/services">All Services</a><br /><a href="/quote">Request a Quote</a><br /><a href="/contact">Contact</a></p>
    </div>
  </div>
  <div class="container legal">© {new Date().getFullYear()} Scottish Energy Services. All rights reserved.</div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(242, 247, 251, 0.45) 0%, rgba(239, 244, 249, 0.85) 100%);
    padding-bottom: 2.7rem;
  }
  .footer-grid { display: grid; grid-template-columns: minmax(0, 1.6fr) 1fr 1fr; gap: 1.3rem; }
  .footer-logo { max-width: 260px; margin-bottom: 1rem; }
  .legal { margin-top: 1.2rem; padding-top: 1.2rem; border-top: 1px solid var(--border); color: var(--muted); font-size: .9rem; }
  h4 { margin: .4rem 0 .5rem; color: var(--text-strong); }
  p { margin: 0; color: var(--muted); }
  a:hover { color: var(--brand-strong); }
  @media (max-width: 820px){ .footer-grid { grid-template-columns: 1fr; } }
</style>
