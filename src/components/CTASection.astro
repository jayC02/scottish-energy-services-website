---
const { title = 'Need a dependable compliance partner?', text = 'Speak with our team for practical advice, transparent pricing, and quick scheduling.', button = 'Get in touch' } = Astro.props;
---
<section class="section">
  <div class="container cta-wrap" data-reveal>
    <div class="card cta">
      <p class="eyebrow">Start a Conversation</p>
      <h2>{title}</h2>
      <p>{text}</p>
      <a class="btn btn-primary" href="/contact">{button}</a>
    </div>
  </div>
</section>

<style>
  .cta-wrap { max-width: 960px; }
  .cta {
    text-align: center;
    padding: clamp(1.6rem, 3vw, 2.3rem);
    background: linear-gradient(120deg, #ffffff 0%, #edf5fc 56%, #f1faf7 100%);
    border-color: #cfe0ee;
  }
  h2 { margin: 0; color: var(--text-strong); }
  p { color: var(--muted); max-width: 62ch; margin: .75rem auto 1.2rem; }
</style>
