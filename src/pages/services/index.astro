  <section class="section">
    <div class="container" data-reveal>
      <h1 class="section-title">Our services</h1>
      <p class="lead">A complete nine-service offering for compliance, certification, and building performance — structured for professional teams that need precision, speed, and confidence.</p>
    </div>
  </section>
  <ServiceCards />
  <CTASection title="Need support selecting the right assessment route?" text="Share your property profile and objective, and we will recommend the most efficient compliance pathway." />
</BaseLayout>
