---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCards from '../../components/ServiceCards.astro';
import CTASection from '../../components/CTASection.astro';
---
<BaseLayout title="Services" description="Explore nine premium technical compliance services delivered by Scottish Energy Services across the UK.">
  <section class="section">
    <div class="container" data-reveal>
      <h1 class="section-title">Technical services portfolio</h1>
      <p class="lead">From single-asset assessments to multi-site compliance programmes, we deliver focused technical outputs with reliable scheduling and clear commercial communication.</p>
    </div>
  </section>
  <ServiceCards />
  <CTASection title="Need help selecting the right scope?" text="Tell us where your project is now and what you need to evidence. We will advise the most efficient service path." />
</BaseLayout>
