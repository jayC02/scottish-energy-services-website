---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="The page you requested could not be found.">
  <section class="section">
    <div class="container card" style="text-align:center" data-reveal>
      <h1 class="section-title">Page not found</h1>
      <p class="lead">The page you requested may have moved or no longer exists.</p>
      <a class="btn btn-primary" href="/">Return to homepage</a>
    </div>
  </section>
</BaseLayout>
