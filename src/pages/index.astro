---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCards from '../components/ServiceCards.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CoverageMap from '../components/CoverageMap.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout
  title="Property compliance and building performance services"
  description="Scottish Energy Services provides premium compliance support, including Commercial EPCs, SAPs, SBEM, FRAs, Section 63, DECs, TM59, DSM, and Domestic EPC and Legionella assessments across Scotland."
>
  <Hero />
  <TrustStrip />
  <ServiceCards preview={true} />
  <WhyChooseUs />
  <ProcessSteps />
  <CoverageMap />
  <FAQAccordion limit={3} />
  <CTASection title="Ready to appoint a dependable compliance partner?" text="Tell us your property type, timeline, and objective. We will respond with clear scope, transparent pricing, and next available appointments." button="Request a booking" />
</BaseLayout>
