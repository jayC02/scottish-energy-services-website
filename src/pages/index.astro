---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCards from '../components/ServiceCards.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CoverageMap from '../components/CoverageMap.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout
  title="Scottish Energy Services"
  description="Scottish Energy Services delivers premium technical compliance services including commercial EPCs, SAPs, SBEM calculations, FRAs, and DSM support across the UK."
>
  <Hero />
  <TrustStrip />
  <ServiceCards preview={true} />
  <WhyChooseUs />
  <ProcessSteps />
  <CoverageMap />
  <FAQAccordion limit={6} />
  <CTASection title="Ready to scope your requirement?" text="Share your building type, project stage, and target date. We will return a clear proposal and available delivery window." button="Request a booking" />
</BaseLayout>
