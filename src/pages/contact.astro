---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../data/site';
---
<BaseLayout title="Contact" description="Contact Scottish Energy Services for enquiries, quotes, and appointment availability.">
  <section class="section">
    <div class="container grid grid-2">
      <div data-reveal>
        <h1 class="section-title">Contact us</h1>
        <p class="lead">Tell us what service you need and we will respond with availability, scope, and pricing.</p>
        <p><strong>Phone:</strong> {siteConfig.phone}<br/><strong>Email:</strong> {siteConfig.email}<br/><strong>Base:</strong> {siteConfig.address}</p>
      </div>
      <form class="card" data-reveal name="contact" method="post">
        <label>Name<input required type="text" name="name" /></label>
        <label>Email<input required type="email" name="email" /></label>
        <label>Service needed<select name="service"><option>EPC</option><option>SAP</option><option>FRA</option><option>Legionella</option><option>Commercial EPC</option><option>Commercial Legionella</option></select></label>
        <label>Message<textarea name="message" rows="4"></textarea></label>
        <button class="btn btn-primary" type="submit">Send enquiry</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  form { display: grid; gap: .8rem; }
  label { display: grid; gap: .35rem; color: var(--muted); font-size: .95rem; }
  input, select, textarea { width: 100%; border-radius: 10px; border: 1px solid rgba(255,255,255,.2); background: rgba(0,0,0,.15); color: var(--text); padding: .7rem; }
  input:focus, select:focus, textarea:focus { outline: 2px solid var(--ring); outline-offset: 1px; }
</style>
