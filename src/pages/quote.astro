---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Request a Quote" description="Request a quote for our full compliance service portfolio.">
  <section class="section">
    <div class="container quote-wrap" data-reveal>
      <p class="eyebrow">Request a Quote</p>
      <h1 class="section-title">Request a detailed quote</h1>
      <p class="lead">Share your property details and preferred timing. We will provide a clear scope, fee proposal, and practical next steps.</p>
      <form class="form-shell form-grid" name="quote" method="post">
        <label>Full name<input type="text" required placeholder="Your full name" /></label>
        <label>Email address<input type="email" required placeholder="name@company.co.uk" /></label>
        <label>Phone number<input type="tel" placeholder="Best number to reach you" /></label>
        <label>Property postcode<input type="text" required placeholder="e.g. G2 1AA" /></label>
        <label>Service required<select><option value="">Select a service</option><option>Commercial EPCs</option><option>SAPs</option><option>SBEM Calculations</option><option>Fire Risk Assessments (FRAs)</option><option>Section 63 Assessments</option><option>DECs</option><option>Overheating Assessments (TM59)</option><option>Dynamic Simulation Modelling (DSM)</option><option>Domestic EPCs and Legionellas</option></select></label>
        <label>Property details<textarea rows="5" placeholder="Property type, approximate size, occupancy, and any deadlines"></textarea></label>
        <button class="btn btn-primary" type="submit">Submit quote request</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .quote-wrap { max-width: 780px; }
</style>
