---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout title="About" description="Learn about Scottish Energy Services and our practical approach to compliance assessments delivered across the UK.">
  <section class="section">
    <div class="container grid grid-2">
      <div data-reveal>
        <h1 class="section-title">About Scottish Energy Services</h1>
        <p class="lead">We deliver technical compliance and building performance services with a straightforward commercial approach.</p>
        <p>Based in Glasgow, we support clients throughout the UK, including landlords, developers, design teams, managing agents, and public sector estates teams. Our role is to keep projects moving with accurate assessments, clear reporting, and dependable communication from instruction to issue.</p>
        <p>Whether the requirement is a one-off certificate or a phased multi-site programme, we focus on practical delivery standards and outputs that are actually useful to the people managing the property.</p>
      </div>
      <div class="card" data-reveal>
        <h2>How we work</h2>
        <ul>
          <li>Clear scope and fee proposal before instruction</li>
          <li>Planned survey and modelling workflow with realistic dates</li>
          <li>Reports written for action, not just compliance filing</li>
          <li>Consistent support for repeat instructions and portfolios</li>
        </ul>
      </div>
    </div>
  </section>
  <CTASection title="Need a reliable technical partner?" text="Call 0141 255 1360 or email info@scottishenergyservices.co.uk and we will confirm scope and availability." button="Contact us" />
</BaseLayout>
