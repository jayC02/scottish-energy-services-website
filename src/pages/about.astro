---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout title="About" description="Learn about Scottish Energy Services and our practical approach to compliance assessments delivered across the UK.">
  <section class="section">
    <div class="container grid grid-2">
      <div data-reveal>
        <h1 class="section-title">About Scottish Energy Services</h1>
        <p class="lead">We support clients with dependable energy and compliance assessments that are clear, practical, and professionally delivered.</p>
        <p>Our team works with homeowners, landlords, agents, and commercial clients across the UK who need straightforward support in a regulated environment. We focus on communication, consistency, and high reporting standards.</p>
      </div>
      <div class="card" data-reveal>
        <h2>What we stand for</h2>
        <ul>
          <li>Accurate assessments carried out with care</li>
          <li>Clear, honest advice without unnecessary jargon</li>
          <li>Professional scheduling and responsive communication</li>
          <li>A long-term service mindset for repeat clients</li>
        </ul>
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
