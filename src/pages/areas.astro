---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout title="Coverage" description="Scottish Energy Services is based in Scotland and delivers energy and compliance assessments for projects across the UK.">
  <section class="section">
    <div class="container" data-reveal>
      <h1 class="section-title">UK coverage</h1>
      <p class="lead">Scottish Energy Services is based in Glasgow and supports projects across England, Scotland, Wales, and Northern Ireland. We provide clear appointment planning for one-off instructions and multi-site portfolios.</p>
    </div>
  </section>
  <section class="section" style="padding-top:0">
    <div class="container grid grid-3">
      <article class="card" data-reveal><h2>Scotland</h2><p>Frequent appointments across the Central Belt, Highlands, and regional towns.</p></article>
      <article class="card" data-reveal><h2>England & Wales</h2><p>Structured scheduling for residential and non-domestic projects, including phased delivery programmes.</p></article>
      <article class="card" data-reveal><h2>Northern Ireland</h2><p>Planned delivery windows with project-specific coordination and reporting milestones.</p></article>
    </div>
  </section>
  <CTASection title="Need to confirm coverage for a site?" text="Share the postcode and service requirement and we will confirm programme options quickly." />
</BaseLayout>
